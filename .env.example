# Server
HOST=0.0.0.0
PORT=8080
RUST_LOG=info,marketlens_backend=debug,tower_http=info

# Public app origin supplied by the Ideavibes runtime in production.
SELF_URL=http://localhost:5173
ALLOWED_CORS_ORIGIN=http://localhost:5173

# PostgreSQL - required for all persistent state.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/marketlens
DATABASE_MAX_CONNECTIONS=5
DATABASE_CONNECT_TIMEOUT_SECONDS=5
# Optional override when the provider URL's sslmode is not suitable for the runtime network path.
# Allowed values: disable, prefer, require, verify-ca, verify-full.
DATABASE_SSL_MODE=prefer

# Redis - required for caching, pub/sub, and worker coordination.
REDIS_URL=redis://localhost:6379

# Auth service - use the Ideavibes mctai_session cookie, do not issue app JWTs.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_sahib-bain-13c6-marketlens-fce31e
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Legacy compatibility only. New auth code must not mint a second JWT.
JWT_SECRET=replace-with-a-long-random-secret

# Market and content providers.
MARKET_DATA_PROVIDER_KEY=replace-with-provider-key
NEWS_PROVIDER_KEY=replace-with-provider-key

# Ideavibes email service - server side only, never expose these to browser code.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=replace-with-email-token
